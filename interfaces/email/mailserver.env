# Otto Mailserver Environment Configuration
# docker-mailserver configuration for otto.lk

# Core settings
OVERRIDE_HOSTNAME=mail.otto.lk
DOMAINNAME=otto.lk
POSTMASTER_ADDRESS=postmaster@otto.lk

# SMTP
POSTFIX_INET_PROTOCOLS=ipv4

# IMAP
DOVECOT_INET_PROTOCOLS=ipv4

# TLS/SSL — set to manual so we can provide our own certs
SSL_TYPE=manual

# Network interface inside container (always eth0 in Docker)
NETWORK_INTERFACE=eth0

# Spam filter (disabled for initial setup — enable after DNS confirmed)
ENABLE_RSPAMD=0
RSPAMD_LEARN=0
RSPAMD_GREYLISTING=0

# Security
FAIL2BAN_BLOCKTYPE=drop
ENABLE_FAIL2BAN=0
SPOOF_PROTECTION=1
ENABLE_SRS=1

# Logging
LOG_LEVEL=warn

# DKIM signing
ENABLE_OPENDKIM=1
OPENDKIM_DOMAIN=otto.lk
OPENDKIM_SELECTOR=mail

# Postfix submission
POSTFIX_MESSAGE_SIZE_LIMIT=52428800

# Dovecot quotas
DOVECOT_MAILBOX_FORMAT=maildir
ENABLE_QUOTAS=1

# Postfix admin credentials (for API account management)
POSTFIXADMIN_SETUP_PASSWORD=changeme_before_deploy
