#!/usr/bin/env bash
# pre-push hook: owner-aware gh auth switcher
#
# BEHAVIOR:
#   1. Blocks pushes when .repo-owner is missing (hard enforcement)
#   2. If current gh auth matches .repo-owner → exit 0, push proceeds normally
#   3. If current gh auth doesn't match → switch auth, re-run push with --no-verify,
#      exit 1 to abort the original (which had wrong-account credentials)
#
# EXIT CODES:
#   0 — auth was already correct, push proceeds
#   1 — auth mismatch: re-attempted with correct account (or hard block)
#
# NOTE: When exit 1 with re-attempt, the push DID succeed (via re-attempt).
#       The original git push command exits non-zero but the content is pushed.
#       Use tools/git-safe-push instead of bare 'git push' for clean exit codes.

set -euo pipefail

# Guard: skip hook logic if we're inside a re-attempted push
if [[ "${GH_PUSH_OWNER_ACTIVE:-}" == "1" ]]; then
  exit 0
fi

# Find the repo root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "❌ pre-push: Could not determine repo root. Push blocked." >&2
  exit 1
fi

OWNER_FILE="$REPO_ROOT/.repo-owner"
REMOTE_NAME="${1:-origin}"
REMOTE_URL="${2:-}"

# ── Hard block: .repo-owner missing ──────────────────────────────────────────
if [[ ! -f "$OWNER_FILE" ]]; then
  echo "" >&2
  echo "╔══════════════════════════════════════════════════════════════╗" >&2
  echo "║  ❌  PUSH BLOCKED — .repo-owner file missing                ║" >&2
  echo "╠══════════════════════════════════════════════════════════════╣" >&2
  echo "║                                                              ║" >&2
  echo "║  Every repo must declare its GitHub owner so the correct    ║" >&2
  echo "║  account is used for pushes.                                ║" >&2
  echo "║                                                              ║" >&2
  echo "║  Fix:  echo '<github-username>' > .repo-owner               ║" >&2
  echo "║        git add .repo-owner && git commit -m 'add repo owner'║" >&2
  echo "║                                                              ║" >&2
  echo "║  Valid owners: ottomev | PipiAgent | my3ye                  ║" >&2
  echo "╚══════════════════════════════════════════════════════════════╝" >&2
  echo "" >&2
  exit 1
fi

# Read and trim the owner
OWNER="$(cat "$OWNER_FILE" | tr -d '[:space:]')"

if [[ -z "$OWNER" ]]; then
  echo "❌ pre-push: .repo-owner is empty. Push blocked." >&2
  echo "   Fix: echo '<github-username>' > .repo-owner" >&2
  exit 1
fi

# ── Check current active gh account ──────────────────────────────────────────
CURRENT_USER="$(gh api user --jq '.login' 2>/dev/null | tr -d '[:space:]' || echo "")"

if [[ "$CURRENT_USER" == "$OWNER" ]]; then
  echo "✅ pre-push: gh auth is '$OWNER' — correct for this repo." >&2
  exit 0
fi

# ── Auth mismatch: switch and re-attempt ──────────────────────────────────────
echo "" >&2
echo "⚠️  pre-push: gh auth mismatch — active='$CURRENT_USER', required='$OWNER'" >&2
echo "🔄 pre-push: switching auth to '$OWNER'..." >&2

if ! gh auth switch --user "$OWNER" 2>&1 | grep -E "Switched|error|Error" >&2; then
  echo "❌ pre-push: gh auth switch to '$OWNER' failed." >&2
  echo "   Ensure '$OWNER' is logged in: gh auth login" >&2
  exit 1
fi

echo "✅ pre-push: switched to '$OWNER'. Re-attempting push..." >&2

# Drain stdin (git passed us refspecs — we consume them so the re-attempt uses defaults)
# shellcheck disable=SC2162
while read line; do :; done

# Re-run push with correct auth. --no-verify skips hooks on re-attempt.
GH_PUSH_OWNER_ACTIVE=1 git push --no-verify "$REMOTE_NAME" 2>&1
PUSH_STATUS=$?

if [[ $PUSH_STATUS -eq 0 ]]; then
  echo "✅ pre-push: push to '$REMOTE_NAME' succeeded as '$OWNER'." >&2
else
  echo "❌ pre-push: push to '$REMOTE_NAME' failed (exit $PUSH_STATUS) even as '$OWNER'." >&2
fi

# Exit 1 to abort the original push (re-attempt already pushed the content).
# NOTE: 'git push' will exit non-zero here, but the push DID succeed.
# Use tools/git-safe-push for clean exit codes.
exit 1
