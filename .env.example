# Otto AI — Environment Variables
# Copy this to .env and fill in your values.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=otto
POSTGRES_PASSWORD=changeme
POSTGRES_DB=memory

# ── OpenAI (required for semantic memory embeddings) ────────────────────────
OPENAI_API_KEY=sk-...

# ── Neo4j (temporal knowledge graph) ────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-neo4j
NEO4J_URI=bolt://localhost:7687
